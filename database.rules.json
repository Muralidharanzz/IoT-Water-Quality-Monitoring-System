{
  "rules": {
    "current": {
      ".read": "auth != null",
      ".write": "auth != null",
      ".validate": "newData.hasChildren(['ph', 'tds', 'turbidity', 'temperature'])"
    },
    "history": {
      ".read": "auth != null",
      ".write": "auth != null",
      "$entry": {
        ".validate": "newData.hasChildren(['ph', 'tds', 'turbidity', 'temperature', 'timestamp'])"
      }
    },
    "users": {
      "$uid": {
        ".read": "auth != null && (auth.uid === $uid || root.child('users').child(auth.uid).child('role').val() === 'admin')",
        ".write": "auth != null && ((!data.exists() && auth.uid === $uid) || root.child('users').child(auth.uid).child('role').val() === 'admin')"
      },
      ".read": "auth != null && root.child('users').child(auth.uid).child('role').val() === 'admin'"
    },
    "settings": {
      "$uid": {
        ".read": "auth != null && auth.uid === $uid",
        ".write": "auth != null && auth.uid === $uid"
      }
    },
    "auth_logs": {
      ".read": "auth != null && root.child('users').child(auth.uid).child('role').val() === 'admin'",
      ".write": "auth != null",
      "$log_id": {
        ".validate": "newData.hasChildren(['email', 'name', 'role', 'action', 'timestamp'])"
      }
    }
  }
}